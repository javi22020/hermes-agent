# Hermes Agent — Docker configuration
# Copy to .env and fill in your values. Blank values are ignored.
# Minimal required variables are the uncommented ones.

# LLM PROVIDER
OPENROUTER_API_KEY=
LLM_MODEL=anthropic/claude-opus-4.6
# GLM_API_KEY=
# KIMI_API_KEY=
# MINIMAX_API_KEY=

# MESSAGING PLATFORMS (set at least one)
TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_ALLOWED_USERS=
# WHATSAPP_ENABLED=false
# WHATSAPP_ALLOWED_USERS=15551234567
# GATEWAY_ALLOW_ALL_USERS=false

# TOOL API KEYS
# FIRECRAWL_API_KEY=
# FAL_KEY=
# VOICE_TOOLS_OPENAI_KEY=
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# HONCHO_API_KEY=
# GITHUB_TOKEN=

# RESPONSE PACING
# HERMES_HUMAN_DELAY_MODE=off
# HERMES_HUMAN_DELAY_MIN_MS=800
# HERMES_HUMAN_DELAY_MAX_MS=2500
